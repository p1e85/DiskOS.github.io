10 REM TIC-TAC-TOE FOR DISKOS V1.8
20 DIM B 9
30 VAR P=1
40 VAR W=0
50 CLEAR_SCR
60 DRAW_BOX 10 5 15 15 WHITE
70 PRINT "DISKOS TIC-TAC-TOE"
80 PRINT "PLAYER 1: X | PLAYER 2: O"
90 PRINT "USE 0-8 TO PLACE"
100 PRINT "CURRENT PLAYER: " P
110 INPUT M
120 IF B[M]=0 THEN GOTO 150
130 PRINT "INVALID MOVE!"
140 GOTO 110
150 VAR B[M]=P
160 IF P=1 THEN VAR B[M]=1
170 IF P=2 THEN VAR B[M]=2
180 IF P=1 THEN VAR P=2
190 IF P=2 THEN VAR P=1
200 GOTO 50
210 REM END OF ENGINE